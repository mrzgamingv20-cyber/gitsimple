<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0D1117">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GitSimple"
        android:textSize="32sp"
        android:textColor="#E6EDF3"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GitHub client yang lebih simpel"
        android:textSize="14sp"
        android:textColor="#8B949E"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etToken"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan GitHub Token"
        android:textColorHint="#8B949E"
        android:textColor="#E6EDF3"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Login"
        android:backgroundTint="#238636"
        android:textColor="#FFFFFF"/>

</LinearLayout>
